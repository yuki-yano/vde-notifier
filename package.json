{
  "name": "vde-notifier",
  "version": "0.1.10",
  "description": "tmux focus notification CLI for macOS",
  "type": "module",
  "bin": {
    "vde-notifier": "dist/cli.js"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "swift:test": "env -u LIBRARY_PATH swift test --package-path app/vde-notifier-app",
    "swift:test:strict": "env -u LIBRARY_PATH swift test --package-path app/vde-notifier-app -Xswiftc -strict-concurrency=complete -Xswiftc -warnings-as-errors",
    "swift:build": "env -u LIBRARY_PATH swift build --package-path app/vde-notifier-app --product vde-notifier-app",
    "swift:app": "app/vde-notifier-app/scripts/build-app.sh",
    "swift:release-asset": "app/vde-notifier-app/scripts/create-release-asset.sh",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "pack:check": "pnpm run build && npm pack --dry-run --json --ignore-scripts | node scripts/verify-npm-pack.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "pnpm run format:check && pnpm run typecheck && pnpm run lint && pnpm run test:coverage && pnpm run pack:check",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run ci"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "execa": "^9.6.1",
    "kleur": "^4.1.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsdown": "^0.22.8",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "tmux",
    "notification",
    "focus",
    "macos"
  ],
  "author": "Yuki Yano",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "os": [
    "darwin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yuki-yano/vde-notifier"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
